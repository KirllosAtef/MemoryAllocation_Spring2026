<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.InitMemoryController"
      styleClass="dialog-root"
      stylesheets="@../css/style.css"
      spacing="14" prefWidth="420">

    <Label text="Initialise Memory" styleClass="dialog-title"/>
    <Separator/>

    <!-- Total size -->
    <GridPane hgap="12" vgap="8" styleClass="form-grid">
        <Label fx:id="lblTotalSize" text="Total Memory Size (bytes):" GridPane.columnIndex="0" GridPane.rowIndex="0"
               styleClass="form-label"/>
        <TextField fx:id="tfTotalSize" text="1024" prefWidth="140"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
    </GridPane>

    <!-- Holes table -->
    <VBox spacing="6">
        <Label text="Initial Free Holes" styleClass="section-label"/>
        <TableView fx:id="holesTable" prefHeight="180" styleClass="data-table" editable="true">
            <columns>
                <TableColumn fx:id="holeStart" text="Start Address" prefWidth="160" editable="true"/>
                <TableColumn fx:id="holeSize"  text="Size (bytes)"  prefWidth="160" editable="true"/>
            </columns>
            <placeholder><Label text="No holes — whole memory will be one free block"/></placeholder>
        </TableView>
        <HBox spacing="8">
            <Button text="＋ Add Hole"    onAction="#onAddHoleRow"    styleClass="btn-success btn-small"/>
            <Button text="－ Remove Row"  onAction="#onRemoveHoleRow" styleClass="btn-danger  btn-small"/>
        </HBox>
    </VBox>

    <Label text="Tip: Leave the table empty to treat the entire memory as one free hole."
           styleClass="hint-label" wrapText="true"/>

    <Separator/>

    <!-- Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#onCancel" styleClass="btn-neutral"/>
        <Button text="OK"     onAction="#onOk"     styleClass="btn-primary" defaultButton="true"/>
    </HBox>

    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
</VBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/11"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.MainController"
            styleClass="root-pane"
            stylesheets="@../css/style.css">

    <!-- ══ TOP TITLE BAR ══ -->
    <top>
        <HBox styleClass="title-bar" alignment="CENTER_LEFT" spacing="12">
            <Label text="⬛" styleClass="title-icon"/>
            <VBox spacing="1">
                <Label text="Memory Allocation Simulator" styleClass="title-main"/>
                <Label text="Segmentation — First-Fit &amp; Best-Fit" styleClass="title-sub"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="● Not Initialised" styleClass="status-badge-idle"/>
            <HBox.margin><Insets right="16"/></HBox.margin>
        </HBox>
    </top>

    <!-- ══ LEFT: PARTITION TABLES (stacked vertically) ══ -->
    <left>
        <VBox styleClass="panel" prefWidth="390" minWidth="340" spacing="0">
            <Label text="Partition Tables" styleClass="panel-header"/>
            <Separator/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        styleClass="table-scroll" hbarPolicy="NEVER">
                <VBox spacing="0">

                    <!-- FREE HOLES -->
                    <VBox styleClass="table-section">
                        <Label text="Free Holes" styleClass="table-section-title"/>
                        <TableView fx:id="freeTable" styleClass="data-table"
                                   VBox.vgrow="ALWAYS" minHeight="120" prefHeight="160">
                            <columns>
                                <TableColumn fx:id="freeStart" text="Start"         prefWidth="110"/>
                                <TableColumn fx:id="freeEnd"   text="End"           prefWidth="110"/>
                                <TableColumn fx:id="freeSize"  text="Size (B)"      prefWidth="120"/>
                            </columns>
                            <placeholder><Label text="No free holes" styleClass="table-placeholder"/></placeholder>
                        </TableView>
                    </VBox>

                    <Separator/>

                    <!-- ALLOCATED BLOCKS -->
                    <VBox styleClass="table-section">
                        <Label text="Allocated Blocks" styleClass="table-section-title"/>
                        <TableView fx:id="allocTable" styleClass="data-table"
                                   VBox.vgrow="ALWAYS" minHeight="120" prefHeight="180">
                            <columns>
                                <TableColumn fx:id="allocProc"  text="Process" prefWidth="68"/>
                                <TableColumn fx:id="allocSeg"   text="Segment" prefWidth="68"/>
                                <TableColumn fx:id="allocStart" text="Start"   prefWidth="60"/>
                                <TableColumn fx:id="allocEnd"   text="End"     prefWidth="60"/>
                                <TableColumn fx:id="allocSize"  text="Size (B)" prefWidth="80"/>
                            </columns>
                            <placeholder><Label text="No allocated blocks" styleClass="table-placeholder"/></placeholder>
                        </TableView>
                    </VBox>

                    <Separator/>

                    <!-- SEGMENT TABLE -->
                    <VBox styleClass="table-section">
                        <Label text="Segment Table" styleClass="table-section-title"/>
                        <HBox spacing="6" alignment="CENTER_LEFT" styleClass="seg-table-header">
                            <Label text="Process:" styleClass="seg-label"/>
                            <ComboBox fx:id="cbSegProcess" promptText="Select…" prefWidth="120"
                                      onAction="#onSegProcessSelected" HBox.hgrow="ALWAYS"/>
                            <Button text="Show" onAction="#onShowSegTable" styleClass="btn-info"/>
                        </HBox>
                        <TableView fx:id="segTable" styleClass="data-table"
                                   VBox.vgrow="ALWAYS" minHeight="120" prefHeight="170">
                            <columns>
                                <TableColumn fx:id="segNum"  text="#"       prefWidth="34"/>
                                <TableColumn fx:id="segName" text="Name"    prefWidth="76"/>
                                <TableColumn fx:id="segBase" text="Base"    prefWidth="76"/>
                                <TableColumn fx:id="segSz"   text="Size (B)" prefWidth="80"/>
                                <TableColumn fx:id="segLim"  text="Limit"   prefWidth="76"/>
                            </columns>
                            <placeholder><Label text="Select a process" styleClass="table-placeholder"/></placeholder>
                        </TableView>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </left>

    <!-- ══ CENTRE: MEMORY DIAGRAM ══ -->
    <center>
        <VBox styleClass="panel" spacing="0">
            <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="8">
                <Label text="Memory Layout" styleClass="panel-header-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="＋" onAction="#onZoomIn"  styleClass="zoom-btn"/>
                <Button text="－" onAction="#onZoomOut" styleClass="zoom-btn"/>
                <HBox.margin><Insets right="6"/></HBox.margin>
            </HBox>
            <Separator/>
            <ScrollPane fx:id="diagramScroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                        styleClass="diagram-scroll" pannable="true">
                <Pane fx:id="diagramPane" styleClass="diagram-pane" minHeight="500"/>
            </ScrollPane>
        </VBox>
    </center>

    <!-- ══ RIGHT: CONTROLS + LOG ══ -->
    <right>
        <VBox styleClass="panel control-panel" prefWidth="270" minWidth="240" spacing="0">
            <Label text="Controls" styleClass="panel-header"/>
            <Separator/>

            <!-- Memory Setup -->
            <VBox styleClass="control-section" spacing="6">
                <Label text="MEMORY SETUP" styleClass="section-label"/>
                <Button fx:id="btnInit" text="⚙ Initialise Memory" maxWidth="Infinity"
                        onAction="#onInitMemory" styleClass="btn-primary"/>
            </VBox>

            <Separator styleClass="thin-sep"/>

            <!-- Unit -->
            <VBox styleClass="control-section" spacing="6">
                <Label text="UNIT" styleClass="section-label"/>
                <!-- ComboBox is typed Unit in controller; FXML just declares the node -->
                <ComboBox fx:id="cbUnit" onAction="#onUnitChanged" maxWidth="Infinity"/>
            </VBox>

            <Separator styleClass="thin-sep"/>

            <!-- Algorithm -->
            <VBox styleClass="control-section" spacing="6">
                <Label text="ALGORITHM" styleClass="section-label"/>
                <fx:define><ToggleGroup fx:id="algGroup"/></fx:define>
                <HBox spacing="10">
                    <RadioButton fx:id="rbFirstFit" text="First-Fit" toggleGroup="$algGroup"
                                 selected="true" styleClass="algo-radio"/>
                    <RadioButton fx:id="rbBestFit"  text="Best-Fit"  toggleGroup="$algGroup"
                                 styleClass="algo-radio"/>
                </HBox>
            </VBox>

            <Separator styleClass="thin-sep"/>

            <!-- Processes -->
            <VBox styleClass="control-section" spacing="6">
                <Label text="PROCESSES" styleClass="section-label"/>
                <HBox spacing="4">
                    <Button text="Add"    maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            onAction="#onAddProcess"    styleClass="btn-success"/>
                    <Button text="Edit"   maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            onAction="#onEditProcess"   styleClass="btn-info"/>
                    <Button text="Delete" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                            onAction="#onDeleteProcess" styleClass="btn-danger"/>
                </HBox>
                <ListView fx:id="processList" prefHeight="130" styleClass="process-list"/>
            </VBox>

            <Separator styleClass="thin-sep"/>

            <!-- Actions -->
            <VBox styleClass="control-section" spacing="6">
                <Label text="ACTIONS" styleClass="section-label"/>
                <Button text="▶  Allocate Selected"   maxWidth="Infinity"
                        onAction="#onAllocate"   styleClass="btn-accent"/>
                <Button text="◀  Deallocate Selected" maxWidth="Infinity"
                        onAction="#onDeallocate" styleClass="btn-warn"/>
            </VBox>

            <Separator styleClass="thin-sep"/>

            <!-- Legend -->
            <VBox styleClass="control-section legend-box" spacing="5">
                <Label text="LEGEND" styleClass="section-label"/>
                <HBox spacing="7" alignment="CENTER_LEFT">
                    <Pane styleClass="legend-free"  prefWidth="16" prefHeight="12"/>
                    <Label text="Free Hole" styleClass="legend-text"/>
                </HBox>
                <HBox spacing="7" alignment="CENTER_LEFT">
                    <Pane styleClass="legend-alloc" prefWidth="16" prefHeight="12"/>
                    <Label text="Allocated Segment" styleClass="legend-text"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- System Log -->
            <VBox VBox.vgrow="ALWAYS" styleClass="log-outer" spacing="0">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="log-header">
                    <Label text="System Log" styleClass="log-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Clear" onAction="#onClearLog" styleClass="btn-small"/>
                </HBox>
                <TextArea fx:id="logArea" editable="false" VBox.vgrow="ALWAYS"
                          prefHeight="160" styleClass="log-area" wrapText="true"/>
            </VBox>
        </VBox>
    </right>

</BorderPane>
